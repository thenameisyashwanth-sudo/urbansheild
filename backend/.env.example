# CORS origins for backend (Render) - required for Vercel frontend
# Add in Render Dashboard: Environment -> CORS_ORIGINS
CORS_ORIGINS=https://urbansheild.vercel.app,http://localhost:5173,http://localhost:3000

# WhatsApp (Twilio) - for trusted contact alerts
# Get these from https://console.twilio.com - use WhatsApp Sandbox for testing
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
